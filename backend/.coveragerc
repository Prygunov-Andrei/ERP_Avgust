[run]
source =
    core
    payments
    supply
    banking
    worklog
    api_public
    estimates
    accounting
    contracts
    kanban_core
    kanban_commercial
    kanban_files
    kanban_rules
    kanban_supply
    kanban_warehouse
    kanban_object_tasks
    llm_services
    objects
    personnel
    pricelists
    supplier_integrations
    catalog
    fns
    finans_assistant
    communications
omit =
    */migrations/*
    */tests/*
    */__pycache__/*
    */admin.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    class Meta:
show_missing = True
precision = 2
# Coverage поднят после добавления 335 тестов (2026-03-22).
# Поднимать по мере добавления тестов. Не снижать.
fail_under = 30
