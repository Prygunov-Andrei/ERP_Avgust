# =============================================================================
# Backend Environment Variables — EXAMPLE
# =============================================================================
# Скопируйте этот файл в .env и заполните реальными значениями
# cp .env.example .env

# Django
DEBUG=True
SECRET_KEY=django-insecure-docker-dev-key-change-in-production

# PostgreSQL / backups
DB_NAME=finans_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
#
# Для локального backend вне Docker с production DB через SSH-туннель:
# 1. ssh -N -L 15432:127.0.0.1:5432 root@<PRODUCTION_IP>
# 2. DB_HOST=localhost
# 3. DB_PORT=15432

ERP_SERVICE_TOKEN=
BACKUP_DIR=/opt/backups/finans_assistant
MINIO_VOLUME_NAME=finans_assistant_minio_data

# Redis (Celery broker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# MinIO / S3 (worklog media)
WORKLOG_S3_ENDPOINT_URL=http://minio:9000
WORKLOG_S3_PUBLIC_URL=http://localhost:9000
WORKLOG_S3_ACCESS_KEY=minioadmin
WORKLOG_S3_SECRET_KEY=minioadmin
WORKLOG_S3_BUCKET_NAME=worklog-media

# MinIO / S3 (kanban files)
KANBAN_S3_ENDPOINT_URL=http://minio:9000
KANBAN_S3_ACCESS_KEY=minioadmin
KANBAN_S3_SECRET_KEY=minioadmin
KANBAN_S3_BUCKET_NAME=files

# MinIO / S3 (portal estimates)
PORTAL_S3_ENDPOINT_URL=http://minio:9000
PORTAL_S3_ACCESS_KEY=minioadmin
PORTAL_S3_SECRET_KEY=minioadmin
PORTAL_S3_BUCKET_NAME=portal-estimates

# Portal
PORTAL_DOMAIN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# ElevenLabs (Scribe v2 — транскрибация голосовых)
ELEVENLABS_API_KEY=

# Sentry (мониторинг ошибок)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Banking Encryption (шифрование банковских секретов)
# Сгенерируйте: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BANK_ENCRYPTION_KEY=

# JWT (API authentication)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=finans-assistant-erp
JWT_AUDIENCE=erp

# LLM Providers (распознавание счетов)
# Нужен хотя бы один. OpenAI — провайдер по умолчанию.
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GROK_API_KEY=

# Breez Integration
BREEZ_API_BASE_URL=https://api.breez.ru/v1
BREEZ_API_AUTH_HEADER=

# FNS (tax service)
FNS_API_KEY=

# ERP Service Token (для доступа бота к ERP API)
ERP_SERVICE_TOKEN=

# Production (only for prod)
PRODUCTION_DOMAIN=
PRODUCTION_IP=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
