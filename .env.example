# =============================================================================
# ERP Avgust — Environment Variables
# =============================================================================
# docker-compose.yml reads these variables.
# Copy to .env and fill with real values:  cp .env.example .env

# --- PostgreSQL ---
DB_NAME=finans_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Полный локальный стек по умолчанию: локальный Postgres + фоновые сервисы.
COMPOSE_PROFILES=local-db,full-stack
#
# Remote DB dev c Mac через SSH-туннель:
# 1. ssh -N -L 15432:127.0.0.1:5432 root@${PRODUCTION_IP}
# 2. DB_HOST=host.docker.internal
# 3. DB_PORT=15432
# 4. COMPOSE_PROFILES=

BACKUP_DIR=/opt/backups/finans_assistant
MINIO_VOLUME_NAME=finans_assistant_minio_data

# --- MinIO / S3 ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Backend (Django) ---
DEBUG=True
SECRET_KEY=django-insecure-docker-dev-key-change-in-production

# --- Frontend (Next.js rewrites) ---
# Defaults work in docker-compose; override for local dev outside docker:
# BACKEND_API_URL=http://localhost:8000
# MINIO_URL=http://localhost:9000

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
BOT_WEBHOOK_URL=
MINI_APP_URL=

# --- LLM / AI Providers ---
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GROK_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Banking ---
BANK_ENCRYPTION_KEY=
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- JWT (for API auth) ---
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=finans-assistant-erp
JWT_AUDIENCE=erp

# --- Breez Integration ---
BREEZ_API_BASE_URL=https://api.breez.ru/v1
BREEZ_API_AUTH_HEADER=

# --- FNS (tax service) ---
FNS_API_KEY=

# --- ERP Service Token (for bot -> ERP API) ---
ERP_SERVICE_TOKEN=

# --- Portal ---
PORTAL_DOMAIN=

# --- Production (set in prod only) ---
PRODUCTION_DOMAIN=
PRODUCTION_IP=

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# --- ElevenLabs ---
ELEVENLABS_API_KEY=

# --- HVAC-specific ---
HCAPTCHA_SECRET_KEY=
TRANSLATION_API_KEY=
