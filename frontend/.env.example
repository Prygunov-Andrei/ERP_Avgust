# Backend API URL
# Локально: http://localhost:8000
# Docker/prod: http://backend:8000 (по умолчанию)
BACKEND_API_URL=http://localhost:8000

# Прод-сервер для проксирования медиа новостей/HVAC
# Только для локальной разработки! Файлы новостей существуют только на проде.
# На продакшне НЕ задавать — rewrites автоматически используют BACKEND_API_URL.
# PROD_MEDIA_URL=https://hvac-info.com

# MinIO (S3-совместимое хранилище файлов)
# Локально: http://localhost:9000
# Docker/prod: http://minio:9000 (по умолчанию)
# MINIO_URL=http://localhost:9000
