# =============================================================================
# F8 Local stand — environment variables.
# Скопируй: cp .env.local.example .env.local; заполни LLM keys и Fernet.
# Грузится через `./dev-local.sh --f8` (не пересекается с backend/.env).
#
# Подробности — docs/epics/F8-public-ismeta/local-dev.md.
# =============================================================================

# --- ERP БД (локальная, postgres-erp-local на 5432) -------------------------
F8_ERP_DB_NAME=finans_assistant
F8_ERP_DB_USER=postgres
F8_ERP_DB_PASSWORD=postgres
F8_ERP_DB_PORT=5432
# DB_* — то, что читает backend/finans_assistant/settings.py.
DB_NAME=finans_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- ismeta БД (локальная, postgres-ismeta-local на 5433) -------------------
F8_ISMETA_DB_NAME=ismeta
F8_ISMETA_DB_USER=ismeta
F8_ISMETA_DB_PASSWORD=ismeta
F8_ISMETA_DB_PORT=5433
# Прямой URL для ismeta-backend (apps/llm_profiles, recognition_jobs).
ISMETA_DATABASE_URL=postgres://ismeta:ismeta@localhost:5433/ismeta

# --- Redis (локальный, redis-local на 6379) ---------------------------------
F8_REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Recognition (локальный recognition-public на 8004) ---------------------
F8_RECOGNITION_PORT=8004
RECOGNITION_URL=http://localhost:8004
RECOGNITION_API_KEY=dev-recognition-key-change-me
# Кладём копии загруженных PDF локально (используется F8-01 pipeline mount).
PDF_STORAGE_PATH=./storage/ismeta-uploads

# --- LLM Provider keys (тестовые / cheap dev keys) --------------------------
# OpenAI используется TD-17g Vision fallback'ом. DeepSeek/Gemini/Grok —
# для seed_llm_profiles.py (F8-04 LLMProfile «Grok 4»).
LLM_API_KEY_OPENAI=
LLM_API_KEY_DEEPSEEK=
LLM_API_KEY_GEMINI=
LLM_API_KEY_XAI=

# Совместимость с docker-compose.yml + backend/.env.example.
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
XAI_API_KEY=

# --- LLM Profile encryption (Fernet) ----------------------------------------
# КРИТИЧНО: должен совпадать с прод-Fernet, иначе encrypted api_key,
# выгруженные с прода, не расшифруются локально (и наоборот).
# Сгенерировать новый: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_PROFILE_ENCRYPTION_KEY=

# --- Django ERP backend (нативно) -------------------------------------------
DEBUG=True
SECRET_KEY=django-insecure-f8-local-stand-change-me
PORTAL_DOMAIN=localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Banking / другие ключи (не нужны для F8, оставь пустыми) ---------------
BANK_ENCRYPTION_KEY=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=finans-assistant-erp
JWT_AUDIENCE=erp
ERP_SERVICE_TOKEN=

# --- Frontend (Next.js на 3000) ---------------------------------------------
# В .env.local frontend'a используется $BACKEND_API_URL и т.д. — здесь
# только переменные, которые читает dev-local.sh / docker-compose.local.yml.
BACKEND_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_VERSION=f8-local

# --- MinIO (если нужен ERP фронт) -------------------------------------------
# F8 локальный стенд НЕ поднимает MinIO по умолчанию (фокус — recognition + БД).
# Если для UI нужны worklog-media — добавь в docker-compose.dev.yml через
# отдельный override.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
