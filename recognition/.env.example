# Recognition Service
RECOGNITION_API_KEY=dev-recognition-key-change-me
# TD-04: LLM API key (OpenAI / DeepSeek / Claude OpenAI-compatible).
# Имя нейтральное — провайдер выбирается через OPENAI_API_BASE.
LLM_API_KEY=sk-...
# DEPRECATED: alias для backward compat, удалится в N+2.
# Если задан LLM_API_KEY — это поле игнорируется.
# OPENAI_API_KEY=sk-...
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
PARSE_TIMEOUT_SECONDS=300
LLM_MODEL=gpt-4o-mini
DPI=200
MAX_PAGE_RETRIES=2
PORT=8003
