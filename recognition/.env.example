# Recognition Service — example .env. Скопируй в .env и заполни секреты.

# === API auth ===
RECOGNITION_API_KEY=dev-recognition-key-change-me

# === LLM provider (OpenAI / DeepSeek / Claude OpenAI-compatible) ===
# TD-04: имя нейтральное — провайдер выбирается через OPENAI_API_BASE.
LLM_API_KEY=sk-...
# DEPRECATED: alias для backward compat, удалится в N+2.
# Если задан LLM_API_KEY — это поле игнорируется.
# OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com

# === Models (по задачам) ===
LLM_MODEL=gpt-4o-mini
LLM_EXTRACT_MODEL=gpt-4o
LLM_CLASSIFY_MODEL=gpt-4o-mini
LLM_MULTIMODAL_MODEL=gpt-4o

# === Service tuning ===
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
PARSE_TIMEOUT_SECONDS=3600
DPI=200
MAX_PAGE_RETRIES=2
PORT=8003

# === TD-17g pipeline (Docling + Camelot + targeted Vision) ===
# IBM Docling extract (TableFormer + DocLayNet) — primary path.
PDF_EXTRACT_VIA_DOCLING=true
PDF_DOCLING_BYPASS_LLM=true
# Camelot lattice fallback для отсканированных и border-heavy таблиц.
PDF_EXTRACT_VIA_CAMELOT=true
# Synthetic header injection для multi-page без header (TD-17a).
PDF_DOCLING_INJECT_HEADER=true
PDF_DOCLING_HEADER_HEIGHT_PT=110.0
# TD-17g — LLM Vision intervention на scanned PDF / broken Cyrillic.
PDF_LLM_VISION_FALLBACK=true
PDF_LLM_SCANNED_THRESHOLD=200
PDF_LLM_CYRILLIC_RATIO_THRESHOLD=0.3
PDF_LLM_VISION_COUNT_TOLERANCE=2

# === F8-01: PDF archive ===
# Если задан — каждый upload копируется в `<path>/<timestamp>-<filename>` до
# парсинга. Production: `/uploads` (volume mount `./storage/ismeta-uploads`).
# Пустая строка — не копируем (default).
PDF_STORAGE_PATH=
